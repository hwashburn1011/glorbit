# glorbit server
PORT=4317
HOST=127.0.0.1

# Data directory (sqlite + transcripts). Default: ~/.glorbit
# GLORBIT_DATA_DIR=/absolute/path/to/data

# Periodic summary prompt cadence (minutes). Default: 5
# GLORBIT_SUMMARY_MINUTES=5

# Log level: debug | info | warn | error. Default: info
# LOG_LEVEL=info

# Escape hatch to bind on non-loopback (dangerous; single-user tool only).
# GLORBIT_ALLOW_NON_LOOPBACK=false
